# Copy this file to .env and fill in real values:
#   cp .env.example .env

# --- Postgres (required) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=byteyourfork
DB_USER=postgres
DB_PASSWORD=

# --- Auth & crypto (required) ---
# Long random string. Generate one with: openssl rand -hex 64
JWT_SECRET=
# 32-byte key as 64 hex chars. Generate with: openssl rand -hex 32
AES_KEY=

# --- URLs ---
PORT=5000
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# --- SMTP (email features) ---
# Leave blank if you don't need email locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Instacart integration (optional) ---
INSTACART_API_BASE=
INSTACART_API_KEY=

# --- Scraper tuning (optional, has sane defaults in code) ---
MEALDB_LIMIT=
SCRAPE_LIMIT=
SCRAPE_DELAY_MS=
SCRAPE_BACKOFF_MS=
